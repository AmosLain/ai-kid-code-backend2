# Environment Configuration for AI Kid Code Backend
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=production
PORT=10000

# OpenAI Configuration
OPENAI_API_KEY=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

# CORS Configuration (comma-separated list of allowed origins)
# IMPORTANT: Add your actual domain here
CORS_ORIGIN=https://enterhere.vip,https://www.enterhere.vip,http://localhost:3000,http://127.0.0.1:5500

# Rate Limiting Configuration
RATE_LIMIT_WINDOW=900000
# 15 minutes in milliseconds (15 * 60 * 1000)

RATE_LIMIT_MAX=10
# Maximum requests per window per IP address

# Optional: Additional Security Settings
# TRUST_PROXY=true
# SESSION_SECRET=your_session_secret_here
