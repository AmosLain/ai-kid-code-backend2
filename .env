# Environment Configuration for AI Kid Code Backend
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=production
PORT=3000

# Security Settings
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=20

# CORS Origins (comma-separated)
CORS_ORIGINS=https://enterhere.vip,https://www.enterhere.vip

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_ERROR=error.log
LOG_FILE_COMBINED=combined.log

# Optional: If you want to use OpenAI instead of Pollinations
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom image generation service
# IMAGE_SERVICE_URL=https://your-custom-service.com

# Database (if you add one later)
# DATABASE_URL=your_database_connection_string

# Session Secret (if you add sessions)
# SESSION_SECRET=your_super_secret_session_key

# Monitoring (if you add services like Sentry)
# SENTRY_DSN=your_sentry_dsn_here

# Email (if you add contact forms)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
